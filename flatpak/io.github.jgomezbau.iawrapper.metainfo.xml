<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.jgomezbau.iawrapper</id>
  <name>IAWrapper</name>
  <summary>Linux desktop wrapper for web-based AI assistants</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <developer id="io.github.jgomezbau">
    <name>Juan Bau</name>
  </developer>

  <description>
    <p>
      IAWrapper is a Linux-first Electron desktop wrapper for AI platforms such as
      ChatGPT, Claude, Gemini, Grok, DeepSeek, and Qwen.
    </p>
    <p>
      It provides isolated sessions per provider, provider-specific desktop launchers,
      Linux packaging, and desktop integration without relying on a browser profile.
    </p>
  </description>

  <launchable type="desktop-id">io.github.jgomezbau.iawrapper.desktop</launchable>

  <url type="homepage">https://github.com/jgomezbau/IAWrapper</url>
  <url type="bugtracker">https://github.com/jgomezbau/IAWrapper/issues</url>
  <url type="vcs-browser">https://github.com/jgomezbau/IAWrapper</url>

  <content_rating type="oars-1.1"/>

  <categories>
    <category>Utility</category>
    <category>Network</category>
    <category>Chat</category>
  </categories>

  <keywords>
    <keyword>AI</keyword>
    <keyword>ChatGPT</keyword>
    <keyword>Claude</keyword>
    <keyword>Grok</keyword>
    <keyword>Gemini</keyword>
    <keyword>DeepSeek</keyword>
    <keyword>Qwen</keyword>
    <keyword>wrapper</keyword>
    <keyword>electron</keyword>
  </keywords>
